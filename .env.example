# Supabase Configuration
# Local Development (default): http://127.0.0.1:54321
# Remote/Production: https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site Configuration
# Use http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Management (Optional, for Stats/Admin)
# Found in Supabase Dashboard Project Settings
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_MANAGEMENT_API_KEY=your-management-api-key

# E2E Testing (Optional)
E2E_EMAIL=admin@example.com
E2E_PASSWORD=your-secure-password
