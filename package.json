{
  "name": "just-memo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "supabase stop --no-backup && npm run supabase:start && next dev -p 3000",
    "dev:remote": "dotenv -e .env.remote -- next dev -p 3000",
    "build": "next build",
    "build:prod": "dotenv -e .env.remote -- next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit 2>&1 || true",
    "check": "npm run format:check && npm run lint && npm run typecheck || true",
    "verify": "npm run check && npm run test:unit && npm run test:integration",
    "test": "npm run test:unit",
    "test:unit": "dotenv -e .env.local -- vitest run --exclude src/server/actions/memos/query.integrated.test.ts --exclude src/server/actions/memos/security.test.ts",
    "test:watch": "dotenv -e .env.local -- vitest --exclude src/server/actions/memos/query.integrated.test.ts --exclude src/server/actions/memos/security.test.ts",
    "test:integration": "dotenv -e .env.local -- vitest run src/server/actions/memos/query.integrated.test.ts src/server/actions/memos/security.test.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "supabase:start": "./scripts/dev-setup.sh",
    "supabase:stop": "supabase stop",
    "supabase:stop:keep": "supabase stop --no-backup",
    "supabase:reset": "supabase stop --no-backup && supabase start",
    "supabase:status": "supabase status",
    "supabase:push": "npx supabase db push",
    "supabase:pull": "npx supabase db pull",
    "types:generate": "npx supabase gen types typescript --local > src/types/database.ts",
    "types:generate:remote": "dotenv -e .env.remote -- npx supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/types/database.ts",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:skip-check": "standard-version --commit-all --release-as",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tiptap/extension-character-count": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-mention": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@tiptap/suggestion": "^3.19.0",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.2",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "tailwind-merge": "^3.4.0",
    "tippy.js": "^6.3.7",
    "use-debounce": "^10.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agentation": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.3",
    "shadcn": "^3.8.4",
    "standard-version": "^9.5.0",
    "supabase": "^2.89.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{css,html,json,md,mdx,mjs,yaml,yml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "standard-version": {
    "scripts": {
      "precommit": "npm run check"
    }
  }
}
