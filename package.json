{
  "name": "just-memo",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/dev-setup.sh && next dev -p 3000",
    "dev:remote": "dotenv -e .env.remote -- next dev -p 3000",
    "build": "next build",
    "build:prod": "dotenv -e .env.remote -- next build",
    "format:all": "prettier . --write",
    "format:staged": "lint-staged",
    "check": "npm run build && npm run test",
    "cli:build": "npm --prefix cli run build",
    "cli:test": "vitest run cli",
    "cli:pack": "cd cli && npm pack --dry-run",
    "check:cli": "npm run cli:build && npm run cli:test && npm run cli:pack",
    "test": "dotenv -e .env.local -- vitest run --exclude src/server/actions/memos/query.integrated.test.ts --exclude src/server/actions/memos/security.test.ts",
    "test:integration": "dotenv -e .env.local -- vitest run src/server/actions/memos/query.integrated.test.ts src/server/actions/memos/security.test.ts",
    "db:reset": "supabase db reset",
    "types:generate": "npx supabase gen types typescript --local > src/types/database.ts",
    "release": "standard-version",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.110.1",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-mention": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/suggestion": "^3.27.3",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.2",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "sileo": "^0.1.5",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.3",
    "shadcn": "^3.8.4",
    "standard-version": "^9.5.0",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{css,html,json,md,mdx,mjs,yaml,yml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "standard-version": {
    "scripts": {
      "precommit": "npm run check"
    }
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "@hono/node-server": "1.19.13",
    "brace-expansion": "5.0.6",
    "eslint": {
      "brace-expansion": "1.1.13"
    },
    "fast-uri": "3.1.2",
    "flatted": "3.4.2",
    "handlebars": "4.7.9",
    "hono": "4.12.25",
    "ip-address": "10.1.1",
    "js-yaml": "4.2.0",
    "lodash": "4.18.0",
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.5",
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "postcss": "8.5.16",
    "qs": "6.15.2",
    "undici": "7.28.0",
    "yaml": "2.8.3"
  }
}
